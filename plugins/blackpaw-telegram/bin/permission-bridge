#!/usr/bin/env bun
/**
 * Claude Code PermissionRequest hook → Telegram approval bridge.
 *
 * Claude invokes this script once per permission prompt. We drop a request
 * file in STATE_DIR/run/, poll for the MCP server's response file, then emit
 * the structured JSON Claude expects on stdout. The MCP server watches the
 * same directory and owns the Telegram round-trip.
 *
 * File-queue instead of unix socket: the MCP child can crash/restart between
 * sessions (v0.3.1 hardened this), but filesystem state survives the gap.
 *
 * Protocol:
 *   write STATE_DIR/run/<id>.req.json atomically
 *   loop {
 *     if STATE_DIR/run/<id>.resp.json exists → read, delete both, emit stdout
 *     if timeout → emit deny("approval timeout")
 *   }
 */

import {
  existsSync,
  readFileSync,
  writeFileSync,
  renameSync,
  rmSync,
  mkdirSync,
} from 'fs'
import { join } from 'path'
import { homedir } from 'os'
import { randomUUID } from 'crypto'

type HookInput = {
  tool_name?: string
  tool_input?: unknown
  cwd?: string
  session_id?: string
  transcript_path?: string
}

type BridgeResponse = {
  decision: 'allow' | 'deny' | 'always'
  reason?: string
}

type HookOutput = {
  hookSpecificOutput: {
    hookEventName: 'PermissionRequest'
    decision: {
      behavior: 'allow' | 'deny'
      updatedPermissions?: Array<{
        type: 'addRules'
        rules: Array<{ toolName: string; ruleContent?: string }>
        behavior: 'allow'
        destination: 'localSettings'
      }>
      // Deny-only, shown to Claude as the reason. Claude Code rejects the
      // decision payload if this is misnamed (e.g. "reason") and falls back
      // to the interactive permission dialog.
      message?: string
    }
  }
}

function stateDir(): string {
  return process.env.TELEGRAM_STATE_DIR ?? join(homedir(), '.claude', 'channels', 'blackpaw-telegram')
}

function readStdinSync(): string {
  // Bun exposes process.stdin but synchronous reads need Bun.stdin or fd 0.
  // Simplest: read all of fd 0 via node fs.
  // readFileSync('/dev/stdin') works on Unix.
  try {
    return readFileSync(0, 'utf8')
  } catch {
    return ''
  }
}

function writeAtomic(path: string, data: string): void {
  const tmp = `${path}.tmp.${process.pid}`
  writeFileSync(tmp, data, { mode: 0o600 })
  renameSync(tmp, path)
}

function emitDeny(message: string): never {
  const out: HookOutput = {
    hookSpecificOutput: {
      hookEventName: 'PermissionRequest',
      decision: { behavior: 'deny', message },
    },
  }
  process.stdout.write(JSON.stringify(out))
  process.exit(0)
}

function emitAllow(
  opts: { persist?: { toolName: string; ruleContent?: string } } = {},
): never {
  const out: HookOutput = {
    hookSpecificOutput: {
      hookEventName: 'PermissionRequest',
      decision: {
        behavior: 'allow',
        ...(opts.persist
          ? {
              updatedPermissions: [
                {
                  type: 'addRules',
                  rules: [opts.persist],
                  behavior: 'allow',
                  destination: 'localSettings',
                },
              ],
            }
          : {}),
      },
    },
  }
  process.stdout.write(JSON.stringify(out))
  process.exit(0)
}

function logBridge(runDir: string, line: string): void {
  try {
    mkdirSync(runDir, { recursive: true, mode: 0o700 })
    writeFileSync(
      join(runDir, 'bridge.log'),
      `[${new Date().toISOString()}] ${line}\n`,
      { flag: 'a', mode: 0o600 },
    )
  } catch { /* best-effort */ }
}

async function main(): Promise<void> {
  const SD = stateDir()
  const RUN_DIR = join(SD, 'run')
  logBridge(RUN_DIR, `hook fired pid=${process.pid}`)

  const raw = readStdinSync()
  let input: HookInput = {}
  try {
    input = raw ? JSON.parse(raw) : {}
  } catch {
    // Malformed hook payload — fail open so we don't block the user's flow with no way out.
    logBridge(RUN_DIR, `malformed stdin: ${raw.slice(0, 200)}`)
    emitDeny('permission-bridge: malformed hook input')
  }

  const toolName = typeof input.tool_name === 'string' ? input.tool_name : 'unknown'
  const cwd = typeof input.cwd === 'string' ? input.cwd : process.cwd()
  const sessionId = typeof input.session_id === 'string' ? input.session_id : ''
  logBridge(RUN_DIR, `tool=${toolName} cwd=${cwd} session=${sessionId}`)

  mkdirSync(RUN_DIR, { recursive: true, mode: 0o700 })

  const id = randomUUID()
  const reqPath = join(RUN_DIR, `${id}.req.json`)
  const respPath = join(RUN_DIR, `${id}.resp.json`)

  const req = {
    id,
    created_at: Date.now(),
    tool_name: toolName,
    tool_input: input.tool_input,
    cwd,
    session_id: sessionId,
  }
  try {
    writeAtomic(reqPath, JSON.stringify(req))
  } catch (err) {
    emitDeny(`permission-bridge: failed to enqueue request (${(err as Error).message})`)
  }

  const timeoutMs = Number(process.env.BLACKPAW_APPROVAL_TIMEOUT_MS ?? 300_000)
  const pollMs = 250
  const deadline = Date.now() + timeoutMs

  let resp: BridgeResponse | undefined
  while (Date.now() < deadline) {
    if (existsSync(respPath)) {
      try {
        resp = JSON.parse(readFileSync(respPath, 'utf8')) as BridgeResponse
      } catch {
        resp = { decision: 'deny', reason: 'permission-bridge: malformed response' }
      }
      break
    }
    await new Promise(r => setTimeout(r, pollMs))
  }

  // Clean up both files before emitting. If cleanup fails, the MCP server's
  // stale-file sweep catches them later.
  for (const p of [reqPath, respPath]) {
    try { rmSync(p, { force: true }) } catch { /* ignore */ }
  }

  if (!resp) {
    logBridge(RUN_DIR, `id=${id} timeout`)
    emitDeny('approval timeout')
  }

  logBridge(RUN_DIR, `id=${id} decision=${resp.decision}`)
  if (resp.decision === 'allow') emitAllow()
  if (resp.decision === 'always') {
    emitAllow({ persist: { toolName, ruleContent: buildRuleContent(toolName, input.tool_input) } })
  }
  emitDeny(resp.reason ?? 'denied via Telegram')
}

/**
 * For tools with a primary string argument (Bash.command, Read.file_path),
 * encode the argument so "Always allow" is scoped rather than wide-open.
 * Unknown shape → no ruleContent, which means "allow all uses of this tool".
 */
function buildRuleContent(tool: string, toolInput: unknown): string | undefined {
  if (!toolInput || typeof toolInput !== 'object') return undefined
  const obj = toolInput as Record<string, unknown>
  if (tool === 'Bash' && typeof obj.command === 'string') return obj.command
  if (tool === 'Read' && typeof obj.file_path === 'string') return obj.file_path
  if (tool === 'Write' && typeof obj.file_path === 'string') return obj.file_path
  if (tool === 'Edit' && typeof obj.file_path === 'string') return obj.file_path
  return undefined
}

void main()
